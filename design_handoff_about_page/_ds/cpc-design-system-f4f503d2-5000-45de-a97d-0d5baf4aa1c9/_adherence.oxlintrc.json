{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/admin/**",
              "components/content/**",
              "components/core/**",
              "components/feedback/**",
              "components/forms/**",
              "components/navigation/**",
              "ui_kits/admin-dashboard/**",
              "ui_kits/public-site/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Barlow|Manrope|Libre Baskerville))/i]",
        "message": "Font not provided by the design system. Available: Barlow, Manrope, Libre Baskerville."
      },
      {
        "selector": "JSXOpeningElement[name.name='AdminButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|children|onClick|key|ref|className|style|children)$/]",
        "message": "<AdminButton> doesn't accept that prop. Declared props: variant, size, children, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='AdminButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|default|success|danger|info)$/]",
        "message": "<AdminButton> variant must be one of 'primary' | 'default' | 'success' | 'danger' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='AdminButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<AdminButton> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='AdminFormField'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|type|toggle|checked|onChange|placeholder|key|ref|className|style|children)$/]",
        "message": "<AdminFormField> doesn't accept that prop. Declared props: label, type, toggle, checked, onChange, placeholder."
      },
      {
        "selector": "JSXOpeningElement[name.name='AdminModal'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|title|children|footer|onClose|key|ref|className|style|children)$/]",
        "message": "<AdminModal> doesn't accept that prop. Declared props: open, title, children, footer, onClose."
      },
      {
        "selector": "JSXOpeningElement[name.name='AdminPanel'] > JSXAttribute > JSXIdentifier[name!=/^(?:heading|children|key|ref|className|style|children)$/]",
        "message": "<AdminPanel> doesn't accept that prop. Declared props: heading, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='AdminStatusTag'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|children|key|ref|className|style|children)$/]",
        "message": "<AdminStatusTag> doesn't accept that prop. Declared props: status, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='AdminStatusTag'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:published|draft|featured|banner|archived)$/]",
        "message": "<AdminStatusTag> status must be one of 'published' | 'draft' | 'featured' | 'banner' | 'archived'."
      },
      {
        "selector": "JSXOpeningElement[name.name='AdminTable'] > JSXAttribute > JSXIdentifier[name!=/^(?:columns|rows|key|ref|className|style|children)$/]",
        "message": "<AdminTable> doesn't accept that prop. Declared props: columns, rows."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: type, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:event|announcement|ongoing|upcoming)$/]",
        "message": "<Badge> type must be one of 'event' | 'announcement' | 'ongoing' | 'upcoming'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|children|onClick|disabled|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, children, onClick, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|glass)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'glass'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:active|children|onClick|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: active, children, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='EventCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:category|title|when|location|description|actions|key|ref|className|style|children)$/]",
        "message": "<EventCard> doesn't accept that prop. Declared props: category, title, when, location, description, actions."
      },
      {
        "selector": "JSXOpeningElement[name.name='FormField'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|type|as|options|value|onChange|placeholder|key|ref|className|style|children)$/]",
        "message": "<FormField> doesn't accept that prop. Declared props: label, type, as, options, value, onChange, placeholder."
      },
      {
        "selector": "JSXOpeningElement[name.name='FormField'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:input|select|textarea)$/]",
        "message": "<FormField> as must be one of 'input' | 'select' | 'textarea'."
      },
      {
        "selector": "JSXOpeningElement[name.name='GlassCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|hover|as|key|ref|className|style|children)$/]",
        "message": "<GlassCard> doesn't accept that prop. Declared props: children, hover, as."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:logoText|links|active|key|ref|className|style|children)$/]",
        "message": "<NavBar> doesn't accept that prop. Declared props: logoText, links, active."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
