# Copy this file to .env and set your values. .env is gitignored (never commit credentials).
#
# Always use Render PostgreSQL (local and production):
#   DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE
# Get the full URL from Render Dashboard → your PostgreSQL service → "Internal Database URL"
# or "External Database URL" for local dev.
#
# Example (replace with your real URL from Render):
# DATABASE_URL=postgresql://cpc_admin:YOUR_PASSWORD@dpg-xxxxx.oregon-postgres.render.com/cpc_newhaven
#
# Optional for sync_db.py (pull from live to local):
# LIVE_DATABASE_URL=postgresql://...
# LOCAL_DATABASE_URL=sqlite:///cpc_newhaven.db

DATABASE_URL=
